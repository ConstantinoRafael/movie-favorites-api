# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=movie_user
POSTGRES_PASSWORD=movie_password
POSTGRES_DB=movie_favorites
POSTGRES_PORT=5432

# Variáveis consumidas pela API (quando persistência for implementada)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=movie_user
DATABASE_PASSWORD=movie_password
DATABASE_NAME=movie_favorites
DATABASE_URL=postgresql://movie_user:movie_password@postgres:5432/movie_favorites

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Autenticação (futuro)
# -----------------------------------------------------------------------------
# JWT_SECRET=
# JWT_EXPIRES_IN=3600s
