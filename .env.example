# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
APP_PORT=3000

# -----------------------------------------------------------------------------
# Banco de dados
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://movie_user:movie_password@localhost:5432/movie_favorites

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# TMDB (The Movie Database)
# -----------------------------------------------------------------------------
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3

# -----------------------------------------------------------------------------
# PostgreSQL (usado apenas pelo Docker Compose para o container postgres)
# -----------------------------------------------------------------------------
POSTGRES_USER=movie_user
POSTGRES_PASSWORD=movie_password
POSTGRES_DB=movie_favorites
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis (usado apenas pelo Docker Compose para o container redis)
# -----------------------------------------------------------------------------
REDIS_PORT=6379
